# .env.example — copy to .env and fill in values
# This file is the ONLY thing that changes between machines

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL with pgvector extension installed
# Local:      postgresql://postgres:password@localhost:5432/recruitment
# Supabase:   postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Shared dev: postgresql://user:pass@192.168.x.x:5432/recruitment
DATABASE_URL=postgresql://postgres:password@localhost:5432/recruitment

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Embedding model ───────────────────────────────────────────────────────────
# "local"  = sentence-transformers (no API cost, runs on CPU, ~80MB download)
# "openai" = text-embedding-3-small (better quality, costs ~$0.00002/resume)
EMBEDDING_MODE=local

# ── File storage ──────────────────────────────────────────────────────────────
# "local" = saves to LOCAL_UPLOAD_DIR, stores relative path in resume_file_url
# "s3"    = uploads to AWS S3, stores s3:// URL
STORAGE_MODE=local
LOCAL_UPLOAD_DIR=./uploads

# AWS S3 (only needed if STORAGE_MODE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=recruitment-resumes
AWS_REGION=us-east-1

# ── Parser ────────────────────────────────────────────────────────────────────
# OpenAI model for resume field extraction
LLM_MODEL=gpt-4o-mini
# Max concurrent PDF parse jobs (tune to your machine)
MAX_WORKERS=4
